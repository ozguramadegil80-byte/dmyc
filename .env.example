POSTGRES_DB=dmyc_dev
POSTGRES_USER=dmyc_app
POSTGRES_PASSWORD=dmyc_dev_password
POSTGRES_HOST_PORT=55432

# Reserved for later phases. Do not use BBTV ports 3000/3001.
DMYC_WEB_PORT=4310
DMYC_API_PORT=4311
DMYC_EXPO_PORT=19010

# Admin panel login and server-to-server API protection.
# Production values must be long, unique, and kept outside source control.
DMYC_ADMIN_USERNAME=admin
DMYC_ADMIN_PASSWORD=change-this-admin-password
DMYC_ADMIN_SESSION_SECRET=change-this-long-session-secret
DMYC_ADMIN_API_KEY=change-this-long-api-key

# Expo mobile devices cannot reach the host API through localhost.
# Set this to your machine LAN IP when testing on a physical phone.
EXPO_PUBLIC_DMYC_API_URL=http://192.168.1.21:4311

# Enables Places Autocomplete and Directions route preview for range planning.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Weather data for HVAC inference and range adjustment (free plan: 1000 calls/day).
# Sign up at openweathermap.org/api → "Current Weather Data" free tier.
# Without this key the weather feature is silently skipped — no errors.
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here
